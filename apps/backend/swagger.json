  "openapi": "3.0.0",
  "info": {
    "title": "OMNIVIS API",
    "description": "API para orquestração logística de solidariedade em desastres naturais",
    "version": "1.0.0",
    "contact": {
      "name": "OMNIVIS Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de desenvolvimento"
    },
    {
      "url": "https://omnivis-backend.railway.app",
      "description": "Servidor de produção"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Verifica se a API está funcionando",
        "responses": {
          "200": {
            "description": "API funcionando",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "message": {
                      "type": "string",
                      "example": "OMNIVIS Backend API"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/voluntarios": {
      "get": {
        "summary": "Listar todos os voluntários",
        "description": "Retorna uma lista de todos os voluntários cadastrados",
        "responses": {
          "200": {
            "description": "Lista de voluntários",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Voluntario"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro ao buscar voluntários"
          }
        }
      },
      "post": {
        "summary": "Criar novo voluntário",
        "description": "Cadastra um novo voluntário no sistema",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VoluntarioCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Voluntário criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voluntario"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao criar voluntário"
          }
        }
      }
    },
    "/api/v1/voluntarios/{id}": {
      "get": {
        "summary": "Buscar voluntário por ID",
        "description": "Retorna os detalhes de um voluntário específico",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Voluntário encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voluntario"
                }
              }
            }
          },
          "404": {
            "description": "Voluntário não encontrado"
          },
          "500": {
            "description": "Erro ao buscar voluntário"
          }
        }
      },
      "put": {
        "summary": "Atualizar voluntário",
        "description": "Atualiza os dados de um voluntário existente",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VoluntarioUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Voluntário atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voluntario"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao atualizar voluntário"
          }
        }
      },
      "delete": {
        "summary": "Deletar voluntário",
        "description": "Remove um voluntário do sistema",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Voluntário deletado"
          },
          "500": {
            "description": "Erro ao deletar voluntário"
          }
        }
      }
    },
    "/api/v1/disponibilidades": {
      "get": {
        "summary": "Listar todas as disponibilidades",
