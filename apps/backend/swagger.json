  "components": {
    "schemas": {
      "Voluntario": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "telefone": {
            "type": "string"
          },
          "localizacao": {
            "type": "string",
            "description": "Coordenadas geográficas no formato 'lat,lng'",
            "example": "-23.5505,-46.6333"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "disponibilidades": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Disponibilidade"
            }
          }
        }
      },
      "VoluntarioCreate": {
        "type": "object",
        "required": ["nome", "email", "telefone", "localizacao"],
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "telefone": {
            "type": "string",
            "minLength": 10
          },
          "localizacao": {
            "type": "string",
            "pattern": "^-?\\d+\\.\\d+,-?\\d+\\.\\d+$"
          }
        }
      },
      "VoluntarioUpdate": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "telefone": {
            "type": "string",
            "minLength": 10
          },
          "localizacao": {
            "type": "string",
            "pattern": "^-?\\d+\\.\\d+,-?\\d+\\.\\d+$"
          }
        }
      },
      "Disponibilidade": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "tipo": {
            "type": "string",
            "enum": ["Saude", "Logistica", "Engenharia"]
          },
          "ativo": {
            "type": "string",
            "description": "Ativo ou recurso disponível (Barco, Caminhao, Drone, CNH-D, etc.)"
          },
          "voluntarioId": {
            "type": "string"
          },
          "voluntario": {
            "$ref": "#/components/schemas/Voluntario"
          }
        }
      },
      "DisponibilidadeCreate": {
        "type": "object",
        "required": ["tipo", "ativo", "voluntarioId"],
        "properties": {
          "tipo": {
            "type": "string",
            "enum": ["Saude", "Logistica", "Engenharia"]
          },
          "ativo": {
            "type": "string"
          },
          "voluntarioId": {
            "type": "string"
          }
        }
      },
      "DisponibilidadeUpdate": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string",
            "enum": ["Saude", "Logistica", "Engenharia"]
          },
          "ativo": {
            "type": "string"
          }
        }
      },
      "Abrigo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "localizacao": {
            "type": "string"
          },
          "capacidade": {
            "type": "integer"
          },
          "ocupacao": {
            "type": "integer"
          },
          "necessidades": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AbrigoCreate": {
        "type": "object",
        "required": ["nome", "localizacao", "capacidade", "ocupacao"],
        "properties": {
          "nome": {
            "type": "string"
          },
          "localizacao": {
            "type": "string"
          },
          "capacidade": {
            "type": "integer"
          },
          "ocupacao": {
            "type": "integer"
          },
          "necessidades": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Doacao": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "doadorId": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["Pendente", "Coletada", "Entregue"]
          },
          "transporteId": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DoacaoCreate": {
        "type": "object",
        "required": ["doadorId", "tipo"],
        "properties": {
          "doadorId": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["Pendente", "Coletada", "Entregue"],
            "default": "Pendente"
          }
        }
      },
      "Pack": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "tipo": {
            "type": "string",
            "enum": ["Reconstrucao", "Limpeza", "Logistica"]
          },
          "membros": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs dos voluntários"
          },
          "disponivel": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "PackCreate": {
        "type": "object",
        "required": ["nome", "tipo", "membros"],
        "properties": {
          "nome": {
            "type": "string"
          },
          "tipo": {
            "type": "string",
            "enum": ["Reconstrucao", "Limpeza", "Logistica"]
          },
          "membros": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disponivel": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "AuthRegister": {
        "type": "object",
        "required": ["email", "password", "nome"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "nome": {
            "type": "string"
          }
        }
      },
      "AuthLogin": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      }
    }
  }
}
