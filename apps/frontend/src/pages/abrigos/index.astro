---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Abrigos - OMNIVIS">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Abrigos</h1>
    
    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
      <h2 class="text-xl font-bold text-green-800 mb-2">Abrigos Disponíveis</h2>
      <p class="text-green-700">Visualize abrigos disponíveis e necessidades atuais.</p>
    </div>

    <div class="bg-white border rounded-lg p-6">
      <h3 class="font-bold mb-4">Lista de Abrigos</h3>
      <p class="text-gray-600">Nenhum abrigo cadastrado no momento.</p>
      <p class="text-sm text-gray-500 mt-2">Funcionalidade em desenvolvimento - aguardando backend.</p>
    </div>

    <a href="/" class="text-green-600 hover:text-green-800 mt-4 inline-block">Voltar para Home</a>
  </main>
</Layout>
