---
import Layout from '../../layouts/Layout.astro';

<Layout title="Abrigos">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Abrigos</h1>
    <p class="text-gray-600 mb-4">
      Lista de abrigos disponíveis para atendimento em situações de desastre.
    </p>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <p className="text-yellow-800">
        Funcionalidade em desenvolvimento. Em breve você poderá visualizar e buscar abrigos.
      </p>
    </div>
  </main>
</Layout>
