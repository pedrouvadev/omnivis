---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OMNIVIS - Orquestrador Logístico de Solidariedade">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-4 text-center">OMNIVIS</h1>
    <p class="text-lg mb-4 text-center">Orquestrador Logístico de Solidariedade</p>
    <p class="text-gray-600 mb-8 text-center">
      Sistema de gestão de capital humano e material para desastres naturais.
    </p>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      <a href="/voluntario" class="block p-6 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-blue-800 mb-2">Sou Voluntário</h2>
        <p class="text-blue-700">Cadastre-se e ofereça sua ajuda em situações de desastre.</p>
      </a>
      <a href="/abrigos" class="block p-6 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-green-800 mb-2">Abrigos</h2>
        <p class="text-green-700">Visualize abrigos disponíveis e necessidades atuais.</p>
      </a>
      <a href="/torre" class="block p-6 bg-purple-50 border border-purple-200 rounded-lg hover:bg-purple-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-purple-800 mb-2">Torre de Controle</h2>
        <p class="text-purple-700">Dashboard administrativo para gestores de crise.</p>
      </a>
      <a href="/packs" class="block p-6 bg-orange-50 border border-orange-200 rounded-lg hover:bg-orange-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-orange-800 mb-2">Gestão de Packs</h2>
        <p class="text-orange-700">Gerencie e convoque equipes de voluntários.</p>
      </a>
    </div>
  </main>
</Layout>
