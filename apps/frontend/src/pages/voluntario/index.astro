---
import Layout from '../../layouts/Layout.astro';

<Layout title="Área do Voluntário">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Área do Voluntário</h1>
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/voluntario/cadastro" class="block p-6 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-blue-800 mb-2">Novo Cadastro</h2>
        <p class="text-blue-700">Cadastre-se como voluntário para ajudar em desastres naturais.</p>
      </a>
      <a href="/voluntario/minhas-disponibilidades" class="block p-6 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100 transition-colors min-h-[48px]">
        <h2 class="text-xl font-bold text-green-800 mb-2">Minhas Disponibilidades</h2>
        <p class="text-green-700">Gerencie suas disponibilidades e competências.</p>
      </a>
    </div>
  </main>
</Layout>
