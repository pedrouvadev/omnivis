---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Área do Voluntário - OMNIVIS">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Área do Voluntário</h1>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
      <h2 class="text-xl font-bold text-blue-800 mb-2">Bem-vindo!</h2>
      <p class="text-blue-700 mb-4">Cadastre-se para oferecer sua ajuda em situações de desastre.</p>
      <a href="/voluntario/cadastro" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors min-h-[48px]">
        Cadastrar como Voluntário
      </a>
    </div>
    <a href="/" class="text-blue-600 hover:text-blue-800">Voltar para Home</a>
  </main>
</Layout>
